<!DOCTYPE html>

<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Хор-бот — справочник</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=IBM+Plex+Mono:wght@400;600&family=Literata:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #f5f0e8;
    --paper: #faf7f2;
    --ink: #1a1510;
    --muted: #6b6055;
    --accent: #c85a1e;
    --gold: #b8860b;
    --green: #2d6a4f;
    --border: #d4c9b8;
    --code-bg: #ede8de;
    --shadow: rgba(26,21,16,0.08);
  }

- { box-sizing: border-box; margin: 0; padding: 0; }

body {
background: var(–bg);
color: var(–ink);
font-family: ‘Literata’, Georgia, serif;
font-size: 17px;
line-height: 1.75;
}

/* ── Header ── */
.site-header {
background: var(–ink);
color: var(–bg);
padding: 48px 24px 40px;
text-align: center;
position: relative;
overflow: hidden;
}
.site-header::before {
content: ‘’;
position: absolute;
inset: 0;
background: repeating-linear-gradient(
-45deg,
transparent,
transparent 18px,
rgba(255,255,255,0.025) 18px,
rgba(255,255,255,0.025) 19px
);
}
.site-header h1 {
font-family: ‘Playfair Display’, serif;
font-size: clamp(2rem, 6vw, 3.5rem);
font-weight: 700;
letter-spacing: -0.02em;
position: relative;
}
.site-header h1 span { color: var(–accent); }
.site-header .tagline {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.78rem;
letter-spacing: 0.12em;
color: #a09080;
margin-top: 12px;
position: relative;
text-transform: uppercase;
}

/* ── TOC ── */
.toc {
max-width: 780px;
margin: 36px auto;
padding: 0 20px;
}
.toc-inner {
background: var(–paper);
border: 1px solid var(–border);
border-radius: 4px;
padding: 28px 32px;
box-shadow: 0 2px 12px var(–shadow);
}
.toc-title {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.7rem;
letter-spacing: 0.15em;
text-transform: uppercase;
color: var(–muted);
margin-bottom: 16px;
}
.toc-list { list-style: none; }
.toc-list li { border-bottom: 1px dotted var(–border); }
.toc-list li:last-child { border-bottom: none; }
.toc-list a {
display: flex;
align-items: center;
gap: 10px;
padding: 8px 0;
color: var(–ink);
text-decoration: none;
font-size: 0.95rem;
transition: color 0.15s;
}
.toc-list a:hover { color: var(–accent); }
.toc-list a .cmd {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.8rem;
color: var(–accent);
min-width: 110px;
}

/* ── Layout ── */
.content {
max-width: 780px;
margin: 0 auto;
padding: 0 20px 80px;
}

/* ── Sections ── */
.section {
background: var(–paper);
border: 1px solid var(–border);
border-radius: 4px;
margin-bottom: 28px;
overflow: hidden;
box-shadow: 0 2px 12px var(–shadow);
animation: fadeUp 0.4s ease both;
}
@keyframes fadeUp {
from { opacity: 0; transform: translateY(16px); }
to   { opacity: 1; transform: translateY(0); }
}

.section-header {
display: flex;
align-items: center;
gap: 14px;
padding: 18px 28px;
border-bottom: 1px solid var(–border);
background: var(–bg);
cursor: pointer;
user-select: none;
}
.section-header h2 {
font-family: ‘Playfair Display’, serif;
font-size: 1.25rem;
font-weight: 700;
flex: 1;
}
.section-header .cmd-badge {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.78rem;
background: var(–ink);
color: var(–bg);
padding: 3px 10px;
border-radius: 3px;
letter-spacing: 0.05em;
}
.section-header .chevron {
font-size: 0.8rem;
color: var(–muted);
transition: transform 0.2s;
}
.section.collapsed .chevron { transform: rotate(-90deg); }
.section-body { padding: 24px 28px; }
.section.collapsed .section-body { display: none; }

h3 {
font-family: ‘Playfair Display’, serif;
font-size: 1.05rem;
margin: 20px 0 8px;
color: var(–ink);
}
h3:first-child { margin-top: 0; }

p { margin-bottom: 14px; }
p:last-child { margin-bottom: 0; }

ul, ol { padding-left: 22px; margin-bottom: 14px; }
li { margin-bottom: 6px; }

strong { font-weight: 600; }

/* ── Code / terminal blocks ── */
.terminal {
background: var(–ink);
color: #d4c9b8;
border-radius: 4px;
padding: 16px 20px;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.82rem;
line-height: 1.65;
margin: 12px 0;
overflow-x: auto;
white-space: pre;
}
.terminal .u { color: #f5f0e8; }
.terminal .b { color: #c85a1e; font-weight: 600; }
.terminal .g { color: #6fcf97; }
.terminal .y { color: #f2c94c; }
.terminal .m { color: #bb86fc; }

code {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.85em;
background: var(–code-bg);
padding: 1px 6px;
border-radius: 3px;
color: var(–accent);
}

/* ── Special blocks ── */
.notice {
border-left: 3px solid var(–accent);
padding: 12px 16px;
background: #fdf4ef;
border-radius: 0 4px 4px 0;
margin: 14px 0;
font-size: 0.92rem;
}
.notice strong { color: var(–accent); }

.tip {
border-left: 3px solid var(–green);
padding: 12px 16px;
background: #f0f7f4;
border-radius: 0 4px 4px 0;
margin: 14px 0;
font-size: 0.92rem;
}

/* ── Rates table ── */
.rates-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 12px;
margin: 14px 0;
}
.rate-card {
border: 1px solid var(–border);
border-radius: 4px;
padding: 16px;
text-align: center;
}
.rate-card .type {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.72rem;
text-transform: uppercase;
letter-spacing: 0.1em;
color: var(–muted);
}
.rate-card .amount {
font-family: ‘Playfair Display’, serif;
font-size: 1.4rem;
font-weight: 700;
margin: 4px 0 2px;
color: var(–ink);
}
.rate-card .sub { font-size: 0.82rem; color: var(–muted); }
.rate-card.right { border-color: var(–gold); background: #fdf9ee; }
.rate-card.left  { border-color: var(–border); }

/* ── Commands table ── */
.cmd-table { width: 100%; border-collapse: collapse; margin: 14px 0; }
.cmd-table th {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.7rem;
text-transform: uppercase;
letter-spacing: 0.1em;
color: var(–muted);
text-align: left;
padding: 6px 12px;
border-bottom: 2px solid var(–border);
}
.cmd-table td {
padding: 10px 12px;
border-bottom: 1px solid var(–border);
font-size: 0.93rem;
vertical-align: top;
}
.cmd-table tr:last-child td { border-bottom: none; }
.cmd-table .cmd-cell {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.82rem;
color: var(–accent);
white-space: nowrap;
}
.cmd-table tr.highlight td { background: #fdf4ef; }

/* ── Situations ── */
.situation {
border: 1px solid var(–border);
border-radius: 4px;
margin-bottom: 12px;
overflow: hidden;
}
.situation-q {
background: var(–bg);
padding: 12px 16px;
font-weight: 600;
font-size: 0.92rem;
display: flex;
align-items: center;
gap: 8px;
}
.situation-a {
padding: 12px 16px;
font-size: 0.92rem;
background: var(–paper);
}
.situation-a code { font-size: 0.8em; }

/* ── Fridge cheatsheet ── */
.fridge {
background: var(–ink);
color: var(–bg);
border-radius: 4px;
padding: 28px;
font-family: ‘IBM Plex Mono’, monospace;
margin: 14px 0;
}
.fridge h4 {
font-family: ‘IBM Plex Mono’, monospace;
text-align: center;
letter-spacing: 0.2em;
font-size: 0.85rem;
margin-bottom: 20px;
border-bottom: 1px solid #3a3530;
padding-bottom: 12px;
}
.fridge-row {
display: flex;
justify-content: space-between;
padding: 6px 0;
font-size: 0.85rem;
border-bottom: 1px dotted #3a3530;
}
.fridge-row:last-child { border-bottom: none; }
.fridge-row .label { color: #a09080; }
.fridge-row .cmd { color: var(–accent); }

.commandments {
margin-top: 20px;
font-size: 0.82rem;
line-height: 1.8;
}
.commandments h4 {
font-size: 0.75rem;
letter-spacing: 0.15em;
color: #a09080;
border-bottom: 1px solid #3a3530;
padding-bottom: 8px;
margin-bottom: 12px;
text-align: left;
}
.commandments ol { padding-left: 20px; }
.commandments li { color: #d4c9b8; margin-bottom: 4px; }

/* ── Calendar steps ── */
.steps { list-style: none; padding: 0; margin: 14px 0; }
.steps li {
display: flex;
gap: 14px;
margin-bottom: 14px;
align-items: flex-start;
}
.step-num {
background: var(–ink);
color: var(–bg);
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.75rem;
font-weight: 600;
width: 26px;
height: 26px;
border-radius: 50%;
display: flex;
align-items: center;
justify-content: center;
flex-shrink: 0;
margin-top: 2px;
}
.steps .step-text { font-size: 0.93rem; }

/* ── Future block ── */
.future-item {
border-left: 3px solid var(–border);
padding: 14px 18px;
margin-bottom: 14px;
font-size: 0.93rem;
}
.future-item h4 {
font-family: ‘Playfair Display’, serif;
font-size: 1rem;
margin-bottom: 6px;
}

/* ── Emoji icons ── */
.icon { font-size: 1.1em; }

/* ── Mobile ── */
@media (max-width: 540px) {
.section-body { padding: 18px; }
.section-header { padding: 14px 18px; }
.rates-grid { grid-template-columns: 1fr; }
.fridge { padding: 18px; }
}
</style>

</head>
